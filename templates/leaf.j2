! Hostname: {{ hostname }}
! IOU L3: routed ports only (no VLANs / SVIs).

hostname {{ hostname }}
ip routing
!
interface {{ loopback.interface }}
 description Router ID / loopback
 ip address {{ loopback.ip }} {{ loopback.mask }}
 ip ospf {{ ospf.process_id }} area {{ ospf.area }}
!
{% if management %}
interface {{ management.interface }}
 description Out-of-band management
 ip address {{ management.ip }} {{ management.mask }}
 no shutdown
!
{% endif %}
{% for intf in fabric_interfaces %}
interface {{ intf.name }}
 description Fabric or gateway (OSPF)
 ip address {{ intf.ip }} {{ intf.mask }}
 no shutdown
 ip ospf {{ ospf.process_id }} area {{ ospf.area }}
 ip ospf network {{ intf.ospf_network }}
!
{% endfor %}
router ospf {{ ospf.process_id }}
 router-id {{ router_id }}
 passive-interface default
{% for name in fabric_interface_names %}
 no passive-interface {{ name }}
{% endfor %}
!
snmp-server community {{ snmp.community }} RO
snmp-server location {{ snmp.location }}
snmp-server contact {{ snmp.contact }}
snmp-server enable traps
snmp-server host {{ snmp.trap_host }} {{ snmp.community }}
!
